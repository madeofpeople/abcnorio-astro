---
export const prerender = ['development', 'staging'].includes(String(process.env.MODE || '').toLowerCase()) ? false : ['full', 'about'].includes(process.env.SCOPE || 'full');

import Layout from '@layouts/page.astro';
import Block from '@components/wp-blocks/generic-block.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { buildPostSeo } from '@util/seo.js';
import { getCollection } from 'astro:content';
import { fetchWpPost } from '@util/fetch-data.js';

const { slug } = Astro.params;
const post: any = await fetchWpPost(
  `${REST_PATH}pages?slug=${encodeURIComponent(slug ?? '')}`,
  (Astro.props as any)?.post,
);

const blocks: any[] = post?.blocks ?? [];
const seo = buildPostSeo({
  post,
  siteUrl: SITE_URL,
  pathname: `/about/${slug}/`
});

export async function getStaticPaths() {
  const scope = process.env.SCOPE || 'full';
  if (scope !== 'full' && scope !== 'about') {
    return [];
  }

  const entries = await getCollection('about_pages');
  return entries.map((entry: any) => ({
    params: { slug: entry.id },
    props: { post: entry.data },
  }));
}


---

<Layout {...seo}>
  <h1 set:html={post.title.rendered}></h1>
  {blocks.map((block: any) => <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks} />)}
</Layout>
