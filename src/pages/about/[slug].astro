---
import Layout from '@layouts/page.astro';
import Block from '@components/wp-blocks/generic-block.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { fetchPostBlocksCachedByPostModified } from '@lib/blocks.js';
import { buildPostSeo } from '@util/seo.js';
import { fetchAllWpItemsWithBuildCache, fetchJsonWithBuildCache } from '@util/build-cache.js';

// define vars are available in the template
const { slug } = Astro.params;
const mode = String(process.env.MODE || '').toLowerCase();
const isLiveDevMode = mode === 'development' || mode === 'staging';
let post = (Astro.props as any)?.post;

if (isLiveDevMode && slug) {
  const livePosts = await fetchJsonWithBuildCache(
    `${REST_PATH}pages?slug=${encodeURIComponent(slug)}`,
    { defaultValue: [], cacheTtlMs: 0 },
  );
  if (Array.isArray(livePosts) && livePosts[0]) {
    post = livePosts[0];
  }
}

const blocks = await fetchPostBlocksCachedByPostModified(post?.id, post?.modified_gmt || post?.modified);
const seo = buildPostSeo({
  post,
  siteUrl: SITE_URL,
  pathname: `/about/${slug}/`
});

export async function getStaticPaths() {
  const scope = process.env.SCOPE || 'full';
  if (scope !== 'full' && scope !== 'about') {
    return [];
  }

  const parentPages = await fetchJsonWithBuildCache(`${REST_PATH}pages?slug=about`, { defaultValue: [] });
  const aboutId = parentPages?.[0]?.id;

  if (!aboutId) {
    return [];
  }

  const posts = await fetchAllWpItemsWithBuildCache(`${REST_PATH}pages?parent=${aboutId}`, { defaultValue: [] });
  return posts.map((post:any) => ({
    params: { slug: post.slug },
    props: { post: post },
  }));
}


---

<Layout>
  <h1 set:html={post.title.rendered}></h1>
</Layout>
