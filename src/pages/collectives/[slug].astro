---
export const prerender = ['development', 'staging'].includes(String(process.env.MODE || '').toLowerCase()) ? false : ['full', 'collectives'].includes(process.env.SCOPE || 'full');

import Layout from '@layouts/sidebar.astro';
import Block from '@components/wp-blocks/generic-block.astro';
import CollectiveEventsPanel from '@components/Events/Collective-Events-Panel.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { buildPostSeo } from '@util/seo.js';
import { getCollection, getEntry } from 'astro:content';
import { fetchWpPost } from '@util/fetch-data.js';

const { slug } = Astro.params;
const post: any = await fetchWpPost(
  `${REST_PATH}collectives?slug=${encodeURIComponent(slug ?? '')}`,
  (Astro.props as any)?.post,
);

const blocks: any[] = post?.blocks ?? [];
const seo = buildPostSeo({
  post,
  siteUrl: SITE_URL,
  pathname: `/collectives/${slug}/`
});
const collectiveTermId = post?.['collective-associations']?.[0];

export async function getStaticPaths() {
  const scope = process.env.SCOPE || 'full';
  if (scope !== 'full' && scope !== 'collectives') {
    return [];
  }

  const entries = await getCollection('collectives');
  return entries.map((entry: any) => ({
    params: { slug: entry.id },
    props: { post: entry.data },
  }));
}

---

<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogImage={seo.ogImage}>

  <header slot="header">
    <h1 set:html={post.title.rendered}></h1>
  </header>

  <article slot="main">
    { blocks.map((block: any) => (
      <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks || null} />
    ))}
  </article>

  <aside slot="sidebar">
      {collectiveTermId && (
        <h2>Upcoming Events</h2>
        <CollectiveEventsPanel collectiveTermId={collectiveTermId} limit={3} />
      )}
  </aside>
</Layout>



