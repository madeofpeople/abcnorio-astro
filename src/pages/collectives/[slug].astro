---
import Layout from '/src/layouts/collective.astro';
// import Block from '/src/components/wp-blocks/generic-block.astro';
import { REST_PATH } from "/src/util/api_paths.js";

// define vars are available in the template
const { slug } = Astro.params;


// get the content
const contentPath = `${REST_PATH}collectives/?slug=${slug}`; 
let contentRes = await fetch(contentPath);
let [post] = await contentRes.json();

// Build all collective pages
// The getStaticPaths() is required for static Astro sites.
// It does not have access to other scopes, use import.meta.env to avoid needless duplication.
// As a result, it makes sense to do most of the mapping here rather than in the frontmatter.
export async function getStaticPaths({ routePattern }) {
  let REST_PATH = import.meta.env.DEV_REST_API;
  switch (import.meta.env.BUILD_MODE) {
    case "staging":
      REST_PATH = import.meta.env.STAGING_REST_API;
    break
    case "production":
      REST_PATH = import.meta.env.PRODUCTION_REST_API;
    break;
  }
  let data = await fetch(`${REST_PATH}collectives`);
  let posts = await data.json();
  return posts.map((post:any) => ({
    params: { slug: post.slug },
    props: { post: post },
  }));
}

---
<Layout title={post.title.rendered}>
  <article>
    <h2>{contentPath}</h2>
    <!-- { blocks.blocks.map( (block) => (
        <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks || null} />
      ))} -->
  </article>
</Layout>
