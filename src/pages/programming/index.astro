---
export const prerender = ['development', 'staging'].includes(String(process.env.MODE || '').toLowerCase()) ? false : ['full', 'programming'].includes(process.env.SCOPE || 'full');
import Layout from '@layouts/page.astro';
import Block from '@components/wp-blocks/generic-block.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { buildPostSeo } from '@util/seo.js';
import { getEntry } from 'astro:content';
import { fetchWpPost } from '@util/fetch-data.js';

const post = await fetchWpPost(
  `${REST_PATH}pages?slug=programming`,
  async () => { const e = await getEntry('pages', 'programming'); return (e as any)?.data ?? null; },
);
const blocks: any[] = post?.blocks ?? [];
  post,
  siteUrl: SITE_URL,
  pathname: '/programming/',
});
---

<Layout {...seo}>
  {post && <h1 set:html={post.title.rendered}></h1>}
  {blocks.map((block: any) => <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks} />)}
</Layout>


