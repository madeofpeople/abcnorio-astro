---
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { buildPostSeo } from '@util/seo.js';
import { getCollection } from 'astro:content';
import { fetchWpPost } from '@util/fetch-data.js';
import Layout from '@layouts/landing.astro';
import Block from '@components/wp-blocks/generic-block.astro';

const { slug } = Astro.params;
const post: any = await fetchWpPost(
  `${REST_PATH}pages?slug=${encodeURIComponent(slug ?? '')}`,
  (Astro.props as any)?.post,
);

const blocks: any[] = post?.blocks ?? [];

const seo = buildPostSeo({
  post,
  siteUrl: SITE_URL,
  pathname: `/${slug}/`
});

export async function getStaticPaths() {
  if ((process.env.SCOPE || 'full') !== 'full') {
    return [];
  }

  const reservedSlugs = ['about', 'collectives', 'events', 'programming'];
  const entries = await getCollection('pages');
  return entries
    .filter((entry: any) => entry.id && !reservedSlugs.includes(entry.id))
    .map((entry: any) => ({
      params: { slug: entry.id },
      props: { post: entry.data },
    }));
}
---
<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogImage={seo.ogImage}
>
  <h1 set:html={post?.title?.rendered || ''}></h1>
  {blocks.map((block: any) => (
    <Block
      component={block.name}
      attributes={block.attributes}
      innerBlocks={block.innerBlocks || null}
    />
  ))}
</Layout>
