---
export const prerender = false;
import SearchField from '@components/Search/SearchField.astro';
import SearchResults from '@components/Search/SearchResults.astro';
import Layout from '@layouts/index.astro';

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
---
<Layout title="Search">
    <SearchField q={q} />
    <SearchResults />
</Layout>