---
export const prerender = false;
export const partial = true;

if (!Astro.request.headers.get('HX-Request')) {
    return Astro.redirect('/search');
}

import { SEARCH_API } from '../../util/paths.js';
import { POSTS_PER_PAGE } from '@consts';
import SearchListing from '@components/Search/Listing.astro';
import Pagination from '@components/Pagination/Pagination.astro';

const q = Astro.url.searchParams.get('q')?.trim() ?? '';
const page = parseInt(Astro.url.searchParams.get('page') ?? '1', 10);

let allResults: Array<{ id: number; title: string; url: string; type: string; score: number }> = [];
let error: string | null = null;

if (q.length >= 2) {
    try {
        const res = await fetch(`${SEARCH_API}?q=${encodeURIComponent(q)}`);
        if (res.ok) {
            const data = await res.json();
            const grouped: Record<string, typeof allResults> = data.results ?? {};
            allResults = Object.values(grouped).flat();
        } else {
            error = `Search failed (${res.status})`;
        }
    } catch (e) {
        error = 'Search unavailable';
    }
}

const totalPages = Math.ceil(allResults.length / POSTS_PER_PAGE);
const results = allResults.slice((page - 1) * POSTS_PER_PAGE, page * POSTS_PER_PAGE);
const hrefParams = new URLSearchParams();

if (q.length > 0) {
    hrefParams.set('q', q);
}

const hrefBase = `/search${hrefParams.toString() ? `?${hrefParams.toString()}` : ''}`;
---
<div id="search-results" role="region" aria-label="Search results" aria-busy="false">
    {error && <p class="search__error">{error}</p>}
    {!error && q.length >= 2 && allResults.length === 0 && (
        <p class="search__empty">No results for "{q}".</p>
    )}
    {results.length > 0 && <SearchListing results={results} />}
</div>
<Pagination
    id="search-pagination"
    currentPage={page}
    totalPages={totalPages}
    hxGet="/search/results"
    hrefBase={hrefBase}
    hxTarget="#search-results"
    hxInclude="#search-form"
    oob={true}
/>