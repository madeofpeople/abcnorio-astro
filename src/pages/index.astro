---
export const prerender = ['development', 'staging'].includes(String(process.env.MODE || '').toLowerCase()) ? false : (process.env.SCOPE || 'full') === 'full';

import Layout from '@layouts/home.astro';
import Listing from '@components/Events/Homepage-Events-Listing.astro';
import EventTeaser from '@components/Events/Events-Teaser.astro';
import CollectiveTeaser from '@components/teasers/collective.astro';
import NewsListing from '@components/News/Homepage-News-Listing.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
import { getCollection } from 'astro:content';
import { fetchData } from '@util/fetch-data.js';
import { fetchWpJson } from '@util/wp-fetch.js';

const [events, collectives, news] = await Promise.all([
  fetchData(
    () => fetchWpJson(`${REST_PATH}events?per_page=10`).catch(() => []),
    async () => (await getCollection('events')).map((e: any) => e.data),
  ),
  fetchData(
    () => fetchWpJson(`${REST_PATH}collectives?per_page=50`).catch(() => []),
    async () => (await getCollection('collectives')).map((e: any) => e.data),
  ),
  fetchData(
    () => fetchWpJson(`${REST_PATH}news_items?per_page=10`).catch(() => []),
    async () => (await getCollection('news')).map((e: any) => e.data),
  ),
]);
---
<Layout
  title="ABC No Rio"
  description="ABC No Rio collectives, events, and ongoing programming."
  canonical={`${SITE_URL}/`}
>
  <section>
      <h3 style="font-family: var(--font-family-heading), sans-serif;">Upcoming Events</h3>
      <Listing
        items={events}
        requiredProps={["event_start_date"]}
        teaserComponent={EventTeaser}
      />
      <a href="/events" class="view-all-link">View all events</a>
  </section>

  <section>
      <h3 style="font-family: var(--font-family-heading), sans-serif;">Collectives</h3>
      <Listing
        items={collectives}
        teaserComponent={CollectiveTeaser}
      />
      <a href="/collectives" class="view-all-link">View collectives</a>
  </section>

  <section>
    <h3 style="font-family: var(--font-family-heading), sans-serif;">News</h3>
    <NewsListing items={news} />
    <a href="/news" class="view-all-link">View all news</a>
  </section>

</Layout>