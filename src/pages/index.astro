---
const _mode = String(process.env.MODE || '').toLowerCase();
export const prerender = (_mode === 'development' || _mode === 'staging') ? false : (process.env.SCOPE || 'full') === 'full';

import Layout from '@layouts/index.astro';
import Listing from '@components/Events/Homepage_Listing.astro';
import EventTeaser from '@components/Events/event_teaser.astro';
import CollectiveTeaser from '@components/teasers/collective.astro';
import { SITE_URL, REST_PATH } from '@util/paths.js';
---
<Layout
  title="ABC No Rio"
  description="ABC No Rio collectives, events, and ongoing programming."
  canonical={`${SITE_URL}/`}
>
  <section>

    <section>
      <Listing
        slug={'events'}
        requiredProps={["event_start_date"]}
        teaserComponent={EventTeaser}
      />
    </section>

    <section>
      <Listing
        slug={'collectives'}
        count={7}
        teaserComponent={CollectiveTeaser}
      />
    </section>

</Layout>