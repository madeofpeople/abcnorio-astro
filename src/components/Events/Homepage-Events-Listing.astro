---
import { Debug } from "astro:components";
import { REST_PATH } from "@util/paths.js";
import { fetchJsonWithBuildCache } from '@util/build-cache.js';

import "./_homepage-listing.scss";

interface Props {
  slug: string;
  teaserComponent?: any;
  requiredProps?: string[];
}

const { slug, teaserComponent, requiredProps = [] }: Props = Astro.props;
const results = await fetchJsonWithBuildCache(`${REST_PATH}${slug}`, { defaultValue: [] });

const hasValue = (value: any) => value !== undefined && value !== null && value !== '';
const readRequiredProp = (item: any, prop: string) => {
  if (prop === 'title') {
    return item?.title?.rendered;
  }

  if (prop === 'excerpt') {
    return item?.excerpt?.rendered;
  }

  return item?.[prop] ?? item?.meta?.[prop] ?? item?.acf?.[prop];
};
let items = Array.isArray(results)
  ? results.filter((result: any) => (
      !requiredProps.length || requiredProps.every((prop) => hasValue(readRequiredProp(result, prop)))
    ))
  : [];

items = items.slice(0, 7);

const Tag = teaserComponent ?? Debug;

---
<section class="event_listing listing">
    {items.map((result: any) => (
      <Tag data={result} />
    ))}
</section>

