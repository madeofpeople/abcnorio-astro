---
import "./_homepage-listing.scss";

interface Props {
  items: any[];
  teaserComponent?: any;
  requiredProps?: string[];
}

const { items, teaserComponent, requiredProps = [] }: Props = Astro.props;

const hasValue = (value: any) => value !== undefined && value !== null && value !== '';
const readRequiredProp = (item: any, prop: string) => {
  if (prop === 'title') {
    return item?.title?.rendered;
  }

  if (prop === 'excerpt') {
    return item?.excerpt?.rendered;
  }

  return item?.[prop] ?? item?.meta?.[prop] ?? item?.acf?.[prop];
};

let listing = Array.isArray(items)
  ? items.filter((item: any) => (
      !requiredProps.length || requiredProps.every((prop) => hasValue(readRequiredProp(item, prop)))
    ))
  : [];

listing = listing.slice(0, 7);

import { Debug } from "astro:components";
const Tag = teaserComponent ?? Debug;

---
<section class="event_listing listing">
    {listing.map((result: any) => (
      <Tag data={result} />
    ))}
</section>

