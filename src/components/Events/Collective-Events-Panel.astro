---
import { getCollection } from 'astro:content';
import EventTeaser from "@components/Events/Events-Teaser.astro";

interface Props {
    collectiveTermId: number;
    limit?: number;
    order?: 'asc' | 'desc';
}

const { collectiveTermId, limit = 3, order = 'asc' } = Astro.props;

const now = new Date();
const allEntries = await getCollection('events');

const upcoming = allEntries
    .filter((entry: any) => {
        const assoc: number[] = entry.data?.['collective-associations'] ?? [];
        if (!assoc.includes(collectiveTermId)) return false;
        const startRaw = entry.data?.meta?.event_start_date ?? entry.data?.acf?.event_start_date ?? '';
        return startRaw && new Date(startRaw) >= now;
    })
    .sort((a: any, b: any) => {
        const aMs = new Date(a.data?.meta?.event_start_date ?? '').getTime();
        const bMs = new Date(b.data?.meta?.event_start_date ?? '').getTime();
        return order === 'asc' ? aMs - bMs : bMs - aMs;
    })
    .slice(0, limit);
---
{upcoming.length > 0 && (
    <events-panel>
        {upcoming.map((entry: any) => (
            <EventTeaser data={entry.data} />
        ))}
    </events-panel>
)}
