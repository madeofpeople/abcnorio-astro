---
import { getEvents } from "@lib/events/events.js";
import EventListing from "@components/Events/Events-Listing.astro";

interface Props {
    collectiveTermId: number;
}

const { collectiveTermId } = Astro.props;

const now = new Date().toISOString();

const filters: Record<string, string | number> = {
    orderby: "event_start_date",
    order: "asc",
    collective_association: collectiveTermId,
    event_start_after: now,
};

async function getAllUpcomingEvents(): Promise<any[]> {
    const perPage = 100;
    let page = 1;
    let totalPages = 1;
    const allEvents: any[] = [];

    while (page <= totalPages) {
        const { events: pageEvents, totalPages: pageCount } = await getEvents(filters, { page, perPage });
        totalPages = pageCount;
        allEvents.push(...pageEvents);
        page += 1;
    }

    return allEvents;
}

const events = await getAllUpcomingEvents();
const hasUpcomingEvents = events.length > 0;
---
{hasUpcomingEvents && (
    <events-panel>
        <div class="events_listing">
            <EventListing events={events} />
        </div>
    </events-panel>
)}
