---
import { REST_PATH } from "@util/paths.js";
import { getOrSetRuntimeCache } from "@util/runtime-cache.js";
import "./_events-filters.scss";
import SegmentedControl from "@components/SegmentedControl.astro";

const TAXONOMY_TTL_MS = 5 * 60 * 1000;

interface Props {
    dateFilter?: string;
    eventType?: string;
    collectiveAssociation?: string;
    order?: string;
    eventStartBefore?: string;
    eventStartAfter?: string;
}

const {
    dateFilter = 'upcoming',
    eventType = '',
    collectiveAssociation = '',
    order = 'desc',
    eventStartBefore = '',
    eventStartAfter = '',
} = Astro.props;

const [eventTypes, collectives] = await Promise.all([
    getOrSetRuntimeCache(
        "event-types:list",
        TAXONOMY_TTL_MS,
        async () => {
            const res = await fetch(`${REST_PATH}event-types?per_page=100`);
            return res.ok ? await res.json() : [];
        },
    ),
    getOrSetRuntimeCache(
        "collective-associations:list",
        TAXONOMY_TTL_MS,
        async () => {
            const res = await fetch(`${REST_PATH}collective-associations?per_page=100`);
            return res.ok ? await res.json() : [];
        },
    ),
]);
---

<event-filters class="filter-container">
    <form
        id="event-filters-form"
        method="get"
        action="/events"
        aria-controls="events__listing"
        hx-get="/events/listing"
        hx-target=".events__listing"
        hx-trigger="submit"
        hx-swap="outerHTML swap:0.333s settle:0.333s"
    >
        <section class="filters">

            <!-- <h2 class="ui-label">Filter Events by…</h2> -->
            
            <div>

                <fieldset class="filter-group date-filter">
                    <SegmentedControl
                        name="date-filter"
                        label="Show only"
                        options={[
                            { value: '', label: 'All', checked: dateFilter === '' },
                            { value: 'upcoming', label: 'Upcoming', checked: dateFilter === 'upcoming' },
                            { value: 'past', label: 'Past', checked: dateFilter === 'past' },
                        ]}
                    />
                </fieldset>

                <fieldset class="filter-group event-type">
                    <label for="event_type">Event Type</label>
                    <select id="event_type" name="event_type">
                        <option value="">All</option>
                        {eventTypes.map((et: any) => (
                                <option value={et.id} selected={String(et.id) === eventType}>
                                    {et.name}
                                </option>
                            ))
                        }
                    </select>
                </fieldset>

                {collectives.length > 0 && (
                    <fieldset class="filter-group collective-association">
                        <label for="collective_association">Collective</label>
                        <select id="collective_association" name="collective_association">
                            <option value="">All</option>
                            {collectives.map((c: any) => (
                                <option value={c.id} selected={String(c.id) === collectiveAssociation}>
                                    {c.name}
                                </option>
                            ))}
                        </select>
                    </fieldset>
                )}


                <fieldset class="filter-group date-range">
                    <div>
                        <legend class="ui-label">Date Range</legend>
                        <div>
                            <label for="event_start_after">After </label>
                            <input
                                type="date"
                                id="event_start_after"
                                name="event_start_after"
                                value={eventStartAfter}
                            />
                            and
                            <label for="event_start_before">Before </label>
                            <input
                                type="date"
                                id="event_start_before"
                                name="event_start_before"
                                value={eventStartBefore}
                            />
                        </div>
                    </div>
                </fieldset>

                <fieldset class="filter-group order">
                    <SegmentedControl
                        name="order"
                        label="Order"
                        options={[
                            { value: 'asc', label: 'Asc', checked: order === 'asc' },
                            { value: 'desc', label: 'Desc', checked: order === 'desc' },
                        ]}
                    />
                </fieldset>
                <button id="apply-event-filters" type="submit">
                    Apply Filters
                </button>
            </div>
        </section>
    </form>
    <div
        id="announce"
        class="sr-only"
        role="status"
        aria-live="polite"
        aria-atomic="true"
    >
    </div>
</event-filters>
<script>
    const htmx = (window as any).htmx;
    if (!htmx) {
        // Progressive enhancement fallback: form submit still works without htmx.
    } else {

        // Disable HTMX history caching — back/forward navigation uses browser-native
        // bfcache or a full SSR reload instead of HTMX's localStorage snapshot restore,
        // which could restore stale or unstyled body content.
        (htmx.config as any).disableHistoryCaching = true;
        const filtersEl = document.querySelector("event-filters");

        if (!filtersEl || filtersEl.getAttribute("data-htmx-bound") === "true") {
            // Nothing to bind or already bound on this node.
        } else {
            filtersEl.setAttribute("data-htmx-bound", "true");

            const announceEl = filtersEl.querySelector("#announce");

            const handleBeforeRequest = (event: any) => {
                if (event?.detail?.target?.id !== "events__listing") return;
                event.detail.target.classList.add("is-transitioning-out");
                event.detail.target.setAttribute("aria-busy", "true");
                if (announceEl) {
                    announceEl.textContent = "Loading events.";
                    announceEl.classList.add("announcement_visible");
                    announceEl.classList.remove("sr-only");
                }
            };

            const handleAfterSwap = (event: any) => {
                if (event?.detail?.target?.id !== "events__listing") return;
                const listingEl = event.detail.target;
                listingEl.classList.remove("is-transitioning-out");
                const count = listingEl.querySelectorAll("article").length;
                listingEl.setAttribute("aria-busy", "false");
                if (announceEl) {
                    announceEl.textContent = `Loaded ${count} event${count === 1 ? "" : "s"}.`;
                    announceEl.classList.remove("announcement_visible");
                    announceEl.classList.add("sr-only");
                }
            };

            document.body.addEventListener("htmx:beforeRequest", handleBeforeRequest);
            document.body.addEventListener("htmx:afterSwap", handleAfterSwap);

            // When a date input gets a value, reset the date-filter segmented
            // control to "All" so it stays consistent with the actual query.
            const allRadio = filtersEl.querySelector('input[name="date-filter"][value=""]') as HTMLInputElement | null;
            const resetToAll = () => {
                const after = (filtersEl.querySelector('#event_start_after') as HTMLInputElement)?.value;
                const before = (filtersEl.querySelector('#event_start_before') as HTMLInputElement)?.value;
                if (allRadio && (after || before) && !allRadio.checked) {
                    allRadio.checked = true;
                    allRadio.dispatchEvent(new Event('change', { bubbles: true }));
                }
            };
            filtersEl.querySelector('#event_start_after')?.addEventListener('change', resetToAll);
            filtersEl.querySelector('#event_start_before')?.addEventListener('change', resetToAll);
        }
    }
</script>
