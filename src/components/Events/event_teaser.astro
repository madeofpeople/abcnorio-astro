---
import "./_event_teaser.scss";
const months  = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sept', 'Oct', 'Nov', 'Dec'];
const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

function formatEventDate(raw: string): { datetime: string; label: string } | null {
    if (!raw) return null;
    const d = new Date(raw);
    if (Number.isNaN(d.getTime())) return null;
    const hour = d.getHours() % 12 || 12;
    const minutes = String(d.getMinutes()).padStart(2, '0');
    return {
        datetime: raw.replace(' ', 'T'),
        label: `${weekdays[d.getDay()]}, ${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()} @ ${hour}:${minutes}`,
    };
}

interface Props {
    data: any;
    showTeaser?: boolean;
}

const { data, showTeaser = true }: Props = Astro.props;
const startRaw = data?.meta?.event_start_date ?? data?.acf?.event_start_date ?? '';
const start = formatEventDate(startRaw);
const slug  = data?.slug || '';
const title = data?.title?.rendered || slug || 'Untitled event';
const excerpt = data?.excerpt?.rendered || 'excerpt';
const featuredImage = data?._embedded?.['wp:featuredmedia']?.[0];
const teaserImage = featuredImage?.url ?? '';
const teaserImageAlt = featuredImage?.alt_text ?? '';

---
<article class="teaser events">
    <a href={`/events/${slug}`}>
        {showTeaser && teaserImage && (
            <img src={teaserImage} alt={teaserImageAlt} loading="lazy" decoding="async" />
        )}

        <div class="content">
            {start && <time datetime={start.datetime}>{start.label}</time>}
            <h3 set:html={title}></h3>
            <!-- <div set:html={ excerpt }></div> -->
        </div>
    </a>
</article>
