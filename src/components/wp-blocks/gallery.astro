---
import Block from '@components/wp-blocks/generic-block.astro';

const { component, innerBlocks, attributes } = Astro.props;
---
<style>
    .gallery {
        display: block;
        overflow: hidden;
        overflow-x: auto;
        .images {
            display: flex;
            flex-wrap: nowrap;
            gap: 1rem;
            img {
                box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
                border: 0.75rem #eee solid;
                display: block;
                height: 500px;
                width: auto;
            }
        }
    }
</style>
<section class="gallery">
    <div class="images">
{ 
    (innerBlocks.length) && innerBlocks.map( (block) => (
        <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks || null} />
    ))
}    
    </div>
</section>
