---
const { attributes, props, innerBlocks } = Astro.props;
import Block from '@components/wp-blocks/generic-block.astro';
import { Debug } from 'astro:components';
const Tag = attributes?.tagName || "div";
const styles = {
    display: attributes?.layout?.type,
    flexWrap: attributes?.layout?.flexWrap,
}
---
<Tag class="wp-block-group">
    {innerBlocks && innerBlocks.length > 0 && (
        <div class="wp-block-group__inner-container" style={styles}>
            {innerBlocks.map((block) => (                
                <Block component={block.name} attributes={block.attributes} innerBlocks={block.innerBlocks} />
            ))}
        </div>
    )}
</Tag>
<style>
    .wp-block-group__inner-container {
        gap: 2rem;
    }
</style>