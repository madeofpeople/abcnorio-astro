---
import './_Menu.scss';
import SearchField from '@components/Search/SearchField.astro';

type MenuItem = {
    id: number;
    parent: number;
    title: string;
    url: string;
    target?: string;
    children?: MenuItem[];
};
const { menuData = [] } = Astro.props as { menuData?: MenuItem[] };
const itemsById = new Map<number, MenuItem>();
const hierarchicalMenu: MenuItem[] = [];

const linkRel = (target?: string) => (target === '_blank' ? 'noopener noreferrer' : undefined);

for (const item of menuData) {
    itemsById.set(item.id, { ...item, children: [] });
}

for (const item of itemsById.values()) {
    if (!item.parent) {
        hierarchicalMenu.push(item);
        continue;
    }
    const parentItem = itemsById.get(item.parent);
    if (parentItem) {
        parentItem.children?.push(item);
    } else {
        hierarchicalMenu.push(item);
    }
}
---

<nav-menu>


    <nav aria-expanded="false" aria-label="Primary">

        { Astro.url && Astro.url.pathname === '/search' ? null : <SearchField dest="search"/> }
        <button
            class="toggle"
            type="button"
            aria-label="Toggle primary navigation"
            aria-controls="primary-navigation"
            aria-expanded="false"
        >
            <svg
                aria-hidden="true"
                focusable="false"
                fill="var(--button-color)"
                class="hamburger"
                viewBox="0 0 100 100"
                width="250"
            >
                <rect
                    class="line top"
                    width="80"
                    height="10"
                    x="10"
                    y="25"
                    rx="5"
                >
                </rect>
                <rect
                    class="line middle"
                    width="80"
                    height="10"
                    x="10"
                    y="45"
                    rx="5"
                >
                </rect>
                <rect
                    class="line bottom"
                    width="80"
                    height="10"
                    x="10"
                    y="65"
                    rx="5"
                >
                </rect>
            </svg>
        </button>
        <ul id="primary-navigation">
            {
                hierarchicalMenu.map((item) => (
                    <li class={item.title.toLocaleLowerCase()} aria-expanded="false">
                        <a href={item.url} target={item.target || undefined} rel={linkRel(item.target)}>
                            {item.title}
                        </a>
                        {item.children && item.children.length > 0 && (
                            <button
                                class="subnav__toggle"
                                type="button"
                                aria-haspopup="true"
                                aria-controls={`submenu-${item.id}`}
                                aria-expanded="false"
                                aria-label={`Toggle ${item.title} submenu`}
                            >
                                <svg fill="#fff" viewBox="0 0 30.727 30.727" aria-hidden="true" focusable="false">
                                    <path d="M29.994,10.183L15.363,24.812L0.733,10.184c-0.977-0.978-0.977-2.561,0-3.536c0.977-0.977,2.559-0.976,3.536,0l11.095,11.093L26.461,6.647c0.977-0.976,2.559-0.976,3.535,0C30.971,7.624,30.971,9.206,29.994,10.183z" />
                                </svg>
                            </button>
                        )}

                        {item.children && item.children.length > 0 && (
                            <ul
                                id={`submenu-${item.id}`}
                                aria-label={`${item.title} submenu`}
                                aria-expanded="false"
                            >
                                {item.children.map((child) => (
                                    <li>
                                        <a
                                            href={child.url}
                                            target={child.target || undefined}
                                            rel={linkRel(child.target)}
                                        >
                                            {child.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        )}
                    </li>
                ))
            }
        </ul>
    </nav>
</nav-menu>

<script>
    import { bp } from '@util/breakpoints.js';

    class Menu extends HTMLElement {
        constructor() {
            super();
            const toggle = this.querySelector(".toggle");
            const nav = this.querySelector("nav");
            const subnavToggles = this.querySelectorAll(".subnav__toggle");

            if (toggle instanceof HTMLElement && nav instanceof HTMLElement) {
                toggle.addEventListener("click", (e) => {
                    e.preventDefault();
                    const isExpanded =
                        toggle.getAttribute("aria-expanded") === "true";
                    toggle.setAttribute("aria-expanded", String(!isExpanded));
                    nav.setAttribute("aria-expanded", String(!isExpanded));
                });
            }

            subnavToggles.forEach((subToggle) => {
                const parentLi = subToggle.parentElement;
                const subMenu = parentLi?.querySelector("ul");

                if (!(parentLi instanceof HTMLElement) || !(subMenu instanceof HTMLElement)) {
                    return;
                }

                subToggle.addEventListener("click", (e) => {
                    e.preventDefault();
                    if (document.documentElement.clientWidth > bp('sm')) {
                        // desktop — let hover handle it
                        return;
                    }
                    const isExpanded =
                        subMenu.getAttribute("aria-expanded") === "true";
                    subToggle.setAttribute("aria-expanded", String(!isExpanded));
                    parentLi.setAttribute("aria-expanded", String(!isExpanded));
                    subMenu.setAttribute("aria-expanded", String(!isExpanded));
                });
            });
        }
    }
    customElements.define("nav-menu", Menu);
