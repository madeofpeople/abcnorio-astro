---
interface Result {
    id: number;
    title: string;
    url: string;
    score: number;
    event_start_date?: string;
    type: string;
}

interface Props {
    results: Result[];
}
const { results } = Astro.props;

const months   = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sept', 'Oct', 'Nov', 'Dec'];
const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

function formatEventDate(raw: string): { datetime: string; label: string } | null {
    if (!raw) return null;
    const d = new Date(raw);
    if (Number.isNaN(d.getTime())) return null;
    const hour = d.getHours() % 12 || 12;
    const minutes = String(d.getMinutes()).padStart(2, '0');
    return {
        datetime: raw.replace(' ', 'T'),
        label: `${weekdays[d.getDay()]}, ${months[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()} @ ${hour}:${minutes}`,
    };
}

// Group results by type, preserving score order within each group.
const grouped = results.reduce<Record<string, Result[]>>((acc, r) => {
    (acc[r.type] ??= []).push(r);
    return acc;
}, {});

---
<section class="search__listing listing">
    {Object.entries(grouped).map(([type, items]) => (
        <div class={`search__group search__group--${type}`}>
            <h3 class="search__group-label">{type}</h3>
            {items.map((result) => {
                const start = result.event_start_date ? formatEventDate(result.event_start_date) : null;
                return (
                    <article class="search__result">
                        <a href={result.url}>
                            {start && <time datetime={start.datetime}>{start.label}</time>}
                            <p set:html={result.title}></p>
                        </a>
                    </article>
                );
            })}
        </div>
    ))}
</section>