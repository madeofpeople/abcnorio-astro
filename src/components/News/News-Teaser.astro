---
import "./_news-teaser.scss";

const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

function formatNewsDate(raw: string): { datetime: string; label: string } | null {
    if (!raw) return null;
    const parts = raw.split('-').map(Number);
    if (parts.length < 3 || parts.some(isNaN)) return null;
    const [year, month, day] = parts;
    return {
        datetime: raw,
        label: `${months[month - 1]} ${day}, ${year}`,
    };
}

interface Props {
    data: any;
    showTeaser?: boolean;
}

const { data, showTeaser = true }: Props = Astro.props;
const dateRaw = data?.meta?.news_item_date ?? data?.acf?.news_item_date ?? '';
const date = formatNewsDate(dateRaw);
const slug = data?.slug || '';
const title = data?.title?.rendered || slug || 'Untitled';
const featuredImage = data?._embedded?.['wp:featuredmedia']?.[0];
const teaserImage = featuredImage?.url ?? '';
const teaserImageAlt = featuredImage?.alt_text ?? '';
---
<article class="teaser news">
    <a href={`/news_items/${slug}`}>
        {showTeaser && teaserImage && (
            <img src={teaserImage} alt={teaserImageAlt} loading="lazy" decoding="async" />
        )}
        <div class="content">
            {date && <time datetime={date.datetime}>{date.label}</time>}
            <h3 set:html={title}></h3>
        </div>
    </a>
</article>
<style>
    h3 {
        font-size: 1rem;
    }

    a {
        color: var(--color-text);
        text-decoration: none;
        &:hover {
            color: var(--color-link)
            text-decoration: underline
        }
    }
</style>