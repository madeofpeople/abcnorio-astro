---
import NewsTeaser from "@components/News/News-Teaser.astro";
import "./_homepage-news-listing.scss";

interface Props {
  items: any[];
}

const { items }: Props = Astro.props;

const hasValue = (value: any) => value !== undefined && value !== null && value !== '';
let listing = Array.isArray(items)
    ? items.filter((item: any) => hasValue(item?.meta?.news_item_date ?? item?.acf?.news_item_date))
    : [];

listing = listing.slice(0, 7);
---
<section class="listing">
    {listing.map((item: any) => (
        <NewsTeaser data={item} />
    ))}
</section>
<a href="/news_items" class="view-all-link">View all news</a>
