---
import Head from '@components/Head.astro';
import Header from '@components/Header.astro';
import './_event.scss';
const {
  title,
  description,
  keywords,
  canonical,
  ogImage,
  twitterSite,
  twitterCard,
} = Astro.props;

const slug = Astro.url.pathname.split('/').filter(Boolean).pop() || 'home';

---
<html lang="en">
  <Head
    title={title}
    description={description}
    keywords={keywords}
    canonical={canonical}
    ogImage={ogImage}
    twitterSite={twitterSite}
    twitterCard={twitterCard}
  />
  <body class={`event ${slug}`}>
    <Header />
    <main class="event-layout">
      <article>
        <slot name="event_header"/>
        <slot name="main"/>
        <slot name="sidebar" />
      </article>
    </main>
  </body>
  <script data-goatcounter="https://abcnorio.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</html>