---
import fs from 'node:fs';
import Head from '@components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PushInProgressBanner from '../components/PushInProgressBanner.astro';

const {
  title,
  description,
  keywords,
  canonical,
  ogImage,
  twitterSite,
  twitterCard,
  loadHtmx,
} = Astro.props;

const routeNeedsHtmx = Astro.url.pathname.startsWith('/events') || Astro.url.pathname.startsWith('/search');
const shouldLoadHtmx = loadHtmx ?? routeNeedsHtmx;

const isStaging = process.env.MODE === 'staging';
const pushInProgress = isStaging && fs.existsSync('/app/.push-in-progress');
const slug = Astro.url.pathname.split('/').filter(Boolean).pop() || 'home';

---
<html lang="en">
  <Head
    title={title}
    description={description}
    keywords={keywords}
    canonical={canonical}
    ogImage={ogImage}
    twitterSite={twitterSite}
    twitterCard={twitterCard}
    loadHtmx={shouldLoadHtmx}
  />
  <body class={`${slug}`}>
    {pushInProgress && <PushInProgressBanner />}
    <Header />
    <main>
      <h1>Code test</h1>
      <article>
        <slot /> <!-- your content is injected here -->
      </article>
    </main>
    <Footer />
  </body>
  <script data-goatcounter="https://abcnorio.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</html>