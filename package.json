{
  "name": "abcnr",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "docker-dev": "astro dev --host 0.0.0.0 --port 3033",
    "staging_dev": "MODE=staging npx astro dev",
    "build": "npm run maybe:backup:build && npm run build:site && npm run build:wp-admin-css",
    "maybe:backup:build": "if [ \"$ASTRO_BUILD_BACKUP\" = \"1\" ]; then npm run backup:build; else echo 'Skipping build backup (set ASTRO_BUILD_BACKUP=1 to enable).'; fi",
    "backup:build": "bash ./backup-build.sh",
    "build:site": "npx astro build",
    "build:wp-admin-css": "vite build --config vite.wp-admin-css.config.mjs",
    "build-dev": "MODE=development npx astro build --devOutput",
    "build-staging": "MODE=staging npx astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/check": "^0.9.2",
    "@astrojs/node": "^10.0.5",
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/react": "5.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.0.8",
    "astro-icon": "^1.1.5",
    "astro-mail-obfuscation": "^2.3.4",
    "astro-seo-meta": "^6.0.0",
    "canvas": "^3.2.2",
    "figlet": "^1.11.0",
    "file-saver": "^2.0.5",
    "htmx.org": "^2.0.8",
    "ics": "^3.10.0",
    "luxon": "^3.7.2",
    "moment": "^2.30.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "readline-sync": "^1.4.10",
    "scss-reset": "^1.4.6",
    "sharp": "^0.34.5",
    "sticky-js": "^1.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "postcss": "^8.5.8",
    "sass": "^1.98.0",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended-scss": "^16.0.2",
    "stylelint-config-standard": "^39.0.1"
  }
}
